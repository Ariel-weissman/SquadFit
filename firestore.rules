rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Catch-All Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isMemberOfParty(partyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/parties/$(partyId)/members/$(request.auth.uid));
    }

    // 2. User Profiles Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.avatar is string && data.avatar.size() <= 600
        && data.streak is number
        && data.completionRate is number
        && data.workoutsCompleted is number
        && data.workoutsMissed is number
        && data.weeklyTarget is number
        && data.isSlacking is bool;
    }

    // 3. Parties Collection
    match /parties/{partyId} {
      allow create: if isSignedIn() && isValidParty(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow read: if isSignedIn(); // Metadata can be loaded to join via simple code
      allow update: if isSignedIn() && (isMemberOfParty(partyId) || resource.data.ownerId == request.auth.uid) && isValidParty(request.resource.data);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isValidParty(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.code is string && data.code.size() <= 10
        && data.ownerId is string && data.ownerId.size() <= 128;
    }

    // 4. Subcollection: Party Members
    match /parties/{partyId}/members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(memberId) && isValidMember(request.resource.data);
      allow update, delete: if isSignedIn() && (isOwner(memberId) || get(/databases/$(database)/documents/parties/$(partyId)).data.ownerId == request.auth.uid);
    }

    function isValidMember(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.role is string && data.role.size() <= 50;
    }

    // 5. Subcollection: Active Nudges
    match /parties/{partyId}/nudges/{nudgeId} {
      allow read: if isMemberOfParty(partyId);
      allow create: if isMemberOfParty(partyId) && request.resource.data.fromUser == request.auth.uid && isValidNudge(request.resource.data);
      allow delete: if isMemberOfParty(partyId) && (resource.data.fromUser == request.auth.uid || resource.data.toUser == request.auth.uid);
    }

    function isValidNudge(data) {
      return data.id is string && data.id.size() <= 128
        && data.fromUser is string && data.fromUser.size() <= 128
        && data.toUser is string && data.toUser.size() <= 128
        && data.message is string && data.message.size() <= 500
        && data.channel is string && (data.channel == 'push' || data.channel == 'chat');
    }

    // 6. Subcollection: History Records
    match /parties/{partyId}/history/{historyId} {
      allow read: if isMemberOfParty(partyId);
      allow create: if isMemberOfParty(partyId) && request.resource.data.userId == request.auth.uid && isValidHistory(request.resource.data);
      allow delete: if isMemberOfParty(partyId) && resource.data.userId == request.auth.uid;
    }

    function isValidHistory(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 100
        && data.userAvatar is string && data.userAvatar.size() <= 600
        && data.workoutTitle is string && data.workoutTitle.size() <= 200
        && data.workoutType is string && data.workoutType.size() <= 100;
    }
  }
}
